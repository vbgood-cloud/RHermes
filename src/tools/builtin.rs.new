/// 鏇存柊宸叉湁鎶€鑳界殑鍐呭锛堟墦琛ヤ竵杩涘寲锛?pub struct SkillPatch;

#[async_trait]
impl Tool for SkillPatch {
    fn name(&self) -> &'static str { "skill_patch" }
    fn description(&self) -> &'static str { "鏇存柊宸叉湁鎶€鑳界殑鍐呭锛堟墦琛ヤ竵杩涘寲锛夛紝淇濈暀浣跨敤缁熻" }
    fn parallel_safe(&self) -> bool { false }
    fn parameters(&self) -> Vec<ParamDef> {
        vec![
            ParamDef::required("name", ParamType::String, "瑕佹洿鏂扮殑鎶€鑳藉悕绉?),
            ParamDef::optional("description", ParamType::String, "鏂扮殑鎻忚堪锛岀暀绌轰笉瑕嗙洊"),
            ParamDef::optional("body", ParamType::String, "鏂扮殑鎶€鑳芥鏂?Markdown锛岀暀绌轰笉瑕嗙洊"),
            ParamDef::optional("allowed_tools", ParamType::String, "鏂扮殑宸ュ叿鍒楄〃锛岄€楀彿鍒嗛殧锛岀暀绌轰笉瑕嗙洊"),
        ]
    }
    async fn execute(&self, args: Value) -> Result<String, ToolError> {
        let name = get_string_arg(&args, "name")?;
        let new_description = get_optional_string(&args, "description");
        let new_body = get_optional_string(&args, "body");
        let allowed_tools_str = get_optional_string(&args, "allowed_tools");

        let new_allowed_tools: Option<Vec<String>> = allowed_tools_str.map(|s| {
            s.split(',').map(|t| t.trim().to_string()).filter(|t| !t.is_empty()).collect()
        });

        let engine_arc = GLOBAL_SKILL_ENGINE.get().ok_or_else(|| {
            ToolError::ExecutionFailed("鎶€鑳藉紩鎿庢湭鍒濆鍖?.into())
        })?;

        {
            let mut engine = engine_arc.lock().map_err(|e| {
                ToolError::ExecutionFailed(format!("閿佸畾澶辫触: {e}"))
            })?;

            engine.update_skill(
                &name,
                new_description.as_deref(),
                new_body.as_deref(),
                new_allowed_tools.as_deref(),
                None,
            ).map_err(|e| ToolError::ExecutionFailed(format!("鏇存柊鎶€鑳藉け璐? {e}")))?;
        }

        Ok(format!("鉁?鎶€鑳姐€寋name}銆嶅凡鏇存柊锛佷娇鐢ㄨ褰曪紙娆℃暟/鎴愬姛鐜囷級宸蹭繚鐣欍€?))
    }
