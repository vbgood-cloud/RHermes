/// 灏嗗瓙浠诲姟濮旀墭缁欑嫭绔嬬殑瀛?Agent 鎵ц
///
/// 瀛?Agent 浼氬垱寤轰竴涓嫭绔嬬殑 API 璋冪敤锛屼笓娉ㄤ簬瀹屾垚缁欏畾浠诲姟骞惰繑鍥炵粨鏋溿€?/// 閫傚悎闇€瑕佹繁搴﹀垎鏋愭垨骞惰璋冪爺鐨勫満鏅€?pub struct DelegateTask;

#[async_trait]
impl Tool for DelegateTask {
    fn name(&self) -> &'static str {
        "delegate_task"
    }
    fn description(&self) -> &'static str {
        "灏嗗瓙浠诲姟濮旀墭缁欑嫭绔嬬殑瀛?Agent 鎵ц锛岃繑鍥炲垎鏋愮粨鏋?
    }
    fn parallel_safe(&self) -> bool {
        false
    }
    fn parameters(&self) -> Vec<ParamDef> {
        vec![
            ParamDef::required("task", ParamType::String, "瑕佸瓙 Agent 瀹屾垚鐨勪换鍔℃弿杩?),
            ParamDef::optional("context", ParamType::String, "棰濆鐨勪笂涓嬫枃淇℃伅"),
        ]
    }
    async fn execute(&self, args: Value) -> Result<String, ToolError> {
        let task = get_string_arg(&args, "task")?;
        let context = get_optional_string(&args, "context").unwrap_or_default();

        let config = GLOBAL_CONFIG.get().ok_or_else(|| {
            ToolError::ExecutionFailed("瀛?Agent 閰嶇疆鏈垵濮嬪寲".into())
        })?;

        let result = crate::agent::run_sub_agent(&task, &context, config).await;

        if result.success {
            Ok(format!(
                "銆愬瓙 Agent 缁撴灉銆慭n{}\n銆愯€楁椂: {}ms銆?,
                result.output, result.duration_ms
            ))
        } else {
            Ok(format!("銆愬瓙 Agent 澶辫触銆慭n{}", result.output))
        }
    }
