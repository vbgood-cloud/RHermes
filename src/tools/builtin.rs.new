//! RHermes 鍐呯疆宸ュ叿瀹炵幇
//!
//! 姣忎釜宸ュ叿閮藉疄鐜颁簡 `Tool` trait锛屽苟澹版槑 `parallel_safe` 鏍囧織銆?
use std::path::Path;
use std::sync::Arc;
use std::sync::OnceLock;
use std::time::Duration;

use async_trait::async_trait;
use regex::Regex;
use serde_json::Value;

use crate::tools::{
    get_optional_string, get_string_arg, ParamDef, ParamType, Tool, ToolError,
};

// ---------------------------------------------------------------------------
// read_file 鈥?骞惰瀹夊叏
// ---------------------------------------------------------------------------

pub struct ReadFile;

#[async_trait]
impl Tool for ReadFile {
    fn name(&self) -> &'static str {
        "read_file"
    }
    fn description(&self) -> &'static str {
        "璇诲彇鏂囦欢鍐呭锛屽彲鎸囧畾琛岃寖鍥达紙head/tail/range锛?
    }
    fn parallel_safe(&self) -> bool {
        true
    }
    fn parameters(&self) -> Vec<ParamDef> {
        vec![
            ParamDef::required("path", ParamType::String, "鏂囦欢璺緞"),
            ParamDef::optional("head", ParamType::Integer, "鍙繑鍥炲墠 N 琛?),
            ParamDef::optional("tail", ParamType::Integer, "鍙繑鍥炲悗 N 琛?),
            ParamDef::optional("range", ParamType::String, "琛岃寖鍥村 \"50-100\""),
        ]
    }
    async fn execute(&self, args: Value) -> Result<String, ToolError> {
        let path = get_string_arg(&args, "path")?;
        let content = tokio::fs::read_to_string(&path).await.map_err(ToolError::Io)?;

        let head = args.get("head").and_then(|v| v.as_u64());
        let tail = args.get("tail").and_then(|v| v.as_u64());

        let result = if let Some(n) = head {
            content.lines().take(n as usize).collect::<Vec<_>>().join("\n")
        } else if let Some(n) = tail {
            let lines: Vec<&str> = content.lines().collect();
            let len = lines.len();
            lines[len.saturating_sub(n as usize)..].join("\n")
        } else {
            content
        };

        Ok(format!("[{path}] ({} 瀛楄妭)\n{result}", result.len()))
    }
#OFFICE_MARKER

/// 閫掑綊鏀堕泦鏂囦欢锛堣烦杩囦簩杩涘埗鍜岄殣钘忕洰褰曪級
fn collect_files(dir: &std::path::Path, files: &mut Vec<std::path::PathBuf>) -> std::io::Result<()> {
    if !dir.is_dir() {
        return Ok(());
    }
    for entry in std::fs::read_dir(dir)? {
        let entry = entry?;
        let path = entry.path();
        // 璺宠繃闅愯棌鐩綍 .git, node_modules, target 绛?        if path.is_dir() {
            let name = entry.file_name();
            let s = name.to_string_lossy();
            if s.starts_with('.') || s == "node_modules" || s == "target" || s == "build" {
                continue;
            }
            collect_files(&path, files)?;
        } else if path.is_file() {
            // 鍙悳绱㈡枃鏈枃浠讹紙璺宠繃 .exe .dll .png 绛夛級
            if let Some(ext) = path.extension() {
                let ext = ext.to_string_lossy().to_lowercase();
                match ext.as_str() {
                    "exe" | "dll" | "png" | "jpg" | "gif" | "ico" | "svg"
                    | "woff" | "woff2" | "ttf" | "eot" | "bin" | "o" | "obj"
                    | "pyc" | "pyo" | "lock" | "sum" => continue,
                    _ => {}
                }
            }
            files.push(path);
        }
    }
    Ok(())
#OFFICE_MARKER

/// 灏?glob 妯″紡杞崲涓烘鍒欙紙绠€鍗曠増鏈級
fn glob_to_regex(glob: &str) -> Regex {
    let mut re = String::with_capacity(glob.len() + 4);
    re.push('^');
    for ch in glob.chars() {
        match ch {
            '*' => re.push_str(".*"),
            '?' => re.push('.'),
            '.' => re.push_str("\\."),
            '\\' => re.push_str("\\\\"),
            '|' => re.push('|'),
            c if c.is_ascii_punctuation() => {
                re.push('\\');
                re.push(c);
            }
            c => re.push(c),
        }
    }
    re.push('$');
    Regex::new(&re).unwrap_or_else(|_| Regex::new(".*").unwrap())
#OFFICE_MARKER

// ---------------------------------------------------------------------------
// search_content 鈥?骞惰瀹夊叏
// ---------------------------------------------------------------------------

pub struct SearchContent;

#[async_trait]
impl Tool for SearchContent {
    fn name(&self) -> &'static str {
        "search_content"
    }
    fn description(&self) -> &'static str {
        "鍦ㄦ枃浠朵腑鎼滅储鏂囨湰妯″紡锛岃繑鍥炲尮閰嶇殑鏂囦欢:琛屽彿"
    }
    fn parallel_safe(&self) -> bool {
        true
    }
    fn parameters(&self) -> Vec<ParamDef> {
        vec![
            ParamDef::required("pattern", ParamType::String, "鎼滅储妯″紡锛堟敮鎸佹鍒欙級"),
            ParamDef::optional("path", ParamType::String, "鎼滅储鐩綍锛堥粯璁ら」鐩牴锛?),
            ParamDef::optional("glob", ParamType::String, "鏂囦欢鍚嶈繃婊?),
        ]
    }
    async fn execute(&self, args: Value) -> Result<String, ToolError> {
        let pattern = get_string_arg(&args, "pattern")?;
        let search_path = get_optional_string(&args, "path").unwrap_or_else(|| ".".into());
        let glob_filter = get_optional_string(&args, "glob");

        // 缂栬瘧姝ｅ垯
        let re = Regex::new(&pattern).map_err(|e| {
            ToolError::ExecutionFailed(format!("姝ｅ垯鏃犳晥: {e}"))
        })?;

        // 鏀堕泦瑕佹悳绱㈢殑鏂囦欢
        let mut files: Vec<std::path::PathBuf> = Vec::new();
        let root = std::path::Path::new(&search_path);
        if root.is_file() {
            files.push(root.to_path_buf());
        } else {
            collect_files(root, &mut files).map_err(ToolError::Io)?;
        }

        // 杩囨护 glob
        if let Some(ref g) = glob_filter {
            let glob_re = glob_to_regex(g);
            files.retain(|f| {
                let name = f.to_string_lossy();
                glob_re.is_match(&name)
            });
        }

        // 闄愬埗鎼滅储鏂囦欢鏁帮紙闃叉鐖嗙偢锛?        if files.len() > 5000 {
            files.truncate(5000);
        }

        // 閫愭枃浠舵悳绱?        let max_results = 200;
        let mut results: Vec<String> = Vec::new();

        for file_path in &files {
            if results.len() >= max_results {
                break;
            }
            let content = match tokio::fs::read_to_string(file_path).await {
                Ok(c) => c,
                Err(_) => continue, // 璺宠繃浜岃繘鍒?涓嶅彲璇绘枃浠?            };
            for (line_no, line) in content.lines().enumerate() {
                if re.is_match(line) {
                    results.push(format!("{}:{}:{}", file_path.display(), line_no + 1, line));
                    if results.len() >= max_results {
                        break;
                    }
                }
            }
        }

        if results.is_empty() {
            Ok(format!("鏈壘鍒板尮閰?\"{pattern}\" 鐨勫唴瀹?))
        } else {
            Ok(format!("鎵惧埌 {} 澶勫尮閰?\n{}", results.len(), results.join("\n")))
        }
    }
#OFFICE_MARKER

// ---------------------------------------------------------------------------
// glob 鈥?骞惰瀹夊叏
// ---------------------------------------------------------------------------

pub struct Glob;

#[async_trait]
impl Tool for Glob {
    fn name(&self) -> &'static str {
        "glob"
    }
    fn description(&self) -> &'static str {
        "鎸?glob 妯″紡鍒楀嚭鏂囦欢"
    }
    fn parallel_safe(&self) -> bool {
        true
    }
    fn parameters(&self) -> Vec<ParamDef> {
        vec![
            ParamDef::required("pattern", ParamType::String, "glob 妯″紡濡?'**/*.rs'"),
            ParamDef::optional("path", ParamType::String, "鎼滅储鐩綍"),
        ]
    }
    async fn execute(&self, args: Value) -> Result<String, ToolError> {
        let pattern = get_string_arg(&args, "pattern")?;
        let path = get_optional_string(&args, "path").unwrap_or_else(|| ".".into());

        let mut cmd = tokio::process::Command::new("fd");
        cmd.arg("--glob").arg(&pattern).arg(&path);

        let output = cmd.output().await.map_err(|e| {
            ToolError::ExecutionFailed(format!("glob 澶辫触: {e}"))
        })?;

        let stdout = String::from_utf8_lossy(&output.stdout).to_string();
        let files: Vec<&str> = stdout.lines().filter(|l| !l.is_empty()).collect();
        Ok(format!("鎵惧埌 {} 涓枃浠?\n{}", files.len(), files.join("\n")))
    }
#OFFICE_MARKER

// ---------------------------------------------------------------------------
// write_file 鈥?闈炲苟琛屽畨鍏紙鍓綔鐢級
// ---------------------------------------------------------------------------

pub struct WriteFile;

#[async_trait]
impl Tool for WriteFile {
    fn name(&self) -> &'static str {
        "write_file"
    }
    fn description(&self) -> &'static str {
        "鍐欏叆鏂囦欢锛堝垱寤烘垨瑕嗙洊锛?
    }
    fn parallel_safe(&self) -> bool {
        false
    }
    fn parameters(&self) -> Vec<ParamDef> {
        vec![
            ParamDef::required("path", ParamType::String, "鏂囦欢璺緞"),
            ParamDef::required("content", ParamType::String, "鏂囦欢鍐呭"),
        ]
    }
    async fn execute(&self, args: Value) -> Result<String, ToolError> {
        let path = get_string_arg(&args, "path")?;
        let content = get_string_arg(&args, "content")?;

        // 纭繚鐖剁洰褰曞瓨鍦?        if let Some(parent) = Path::new(&path).parent() {
            tokio::fs::create_dir_all(parent).await.map_err(ToolError::Io)?;
        }

        tokio::fs::write(&path, &content)
            .await
            .map_err(ToolError::Io)?;

        Ok(format!("宸插啓鍏?{} ({} 瀛楄妭)", path, content.len()))
    }
#OFFICE_MARKER

// ---------------------------------------------------------------------------
// run_command 鈥?闈炲苟琛屽畨鍏紙鍓綔鐢級
// ---------------------------------------------------------------------------

pub struct RunCommand;

#[async_trait]
impl Tool for RunCommand {
    fn name(&self) -> &'static str {
        "run_command"
    }
    fn description(&self) -> &'static str {
        "鍦?shell 涓墽琛屽懡浠?
    }
    fn parallel_safe(&self) -> bool {
        false
    }
    fn parameters(&self) -> Vec<ParamDef> {
        vec![
            ParamDef::required("command", ParamType::String, "瑕佹墽琛岀殑鍛戒护锛圵indows 鐢?cmd锛屽叾浠栫敤 sh锛?),
            ParamDef::optional("timeout", ParamType::Integer, "瓒呮椂绉掓暟锛堥粯璁?60锛?),
            ParamDef::optional("cwd", ParamType::String, "宸ヤ綔鐩綍锛堥粯璁ゅ綋鍓嶇洰褰曪級"),
        ]
    }
    async fn execute(&self, args: Value) -> Result<String, ToolError> {
        let command = get_string_arg(&args, "command")?;
        let timeout = args
            .get("timeout")
            .and_then(|v| v.as_u64())
            .unwrap_or(60);

        // Windows 鐢?cmd /c锛屽叾浠栫敤 sh -c
        #[cfg(target_os = "windows")]
        let shell = "cmd";
        #[cfg(not(target_os = "windows"))]
        let shell = "sh";

        #[cfg(target_os = "windows")]
        let flag = "/c";
        #[cfg(not(target_os = "windows"))]
        let flag = "-c";

        let mut cmd = tokio::process::Command::new(shell);
        cmd.arg(flag).arg(&command);

        // 鍙€夌殑宸ヤ綔鐩綍
        if let Some(cwd) = get_optional_string(&args, "cwd") {
            cmd.current_dir(&cwd);
        }

        let output = tokio::time::timeout(Duration::from_secs(timeout), cmd.output())
            .await
            .map_err(|_| ToolError::ExecutionFailed("鍛戒护瓒呮椂".into()))?
            .map_err(|e| ToolError::ExecutionFailed(format!("鍛戒护鎵ц澶辫触: {e}")))?;

        let mut result = String::new();

        let stdout = String::from_utf8_lossy(&output.stdout);
        let stderr = String::from_utf8_lossy(&output.stderr);

        if !stdout.is_empty() {
            result.push_str(&format!("[stdout]\n{stdout}"));
        }
        if !stderr.is_empty() {
            result.push_str(&format!("[stderr]\n{stderr}"));
        }
        if !output.status.success() {
            result.push_str(&format!("\n[閫€鍑虹爜: {}]", output.status.code().unwrap_or(-1)));
        }

        if result.is_empty() {
            result = "鍛戒护鎵ц瀹屾瘯锛堟棤杈撳嚭锛?.into();
        }

        Ok(result)
    }
#OFFICE_MARKER

