pub struct SkillSearch;

#[async_trait]
impl Tool for SkillSearch {
    fn name(&self) -> &'static str { "skill_search" }
    fn description(&self) -> &'static str { "鎸夊叧閿瘝鎼滅储宸插畨瑁呯殑鎶€鑳? }
    fn parallel_safe(&self) -> bool { true }
    fn parameters(&self) -> Vec<ParamDef> {
        vec![ParamDef::required("query", ParamType::String, "鎼滅储鍏抽敭璇?)]
    }
    async fn execute(&self, args: Value) -> Result<String, ToolError> {
        let query = get_string_arg(&args, "query")?;
        let engine_arc = GLOBAL_SKILL_ENGINE.get().ok_or_else(|| ToolError::ExecutionFailed("鎶€鑳藉紩鎿庢湭鍒濆鍖?.into()))?;
        let engine = engine_arc.lock().map_err(|e| ToolError::ExecutionFailed(format!("閿佸畾澶辫触: {e}")))?;
        let results = engine.search(&query);
        if results.is_empty() {
            Ok(format!("鏈壘鍒颁笌銆寋query}銆嶇浉鍏崇殑鎶€鑳?))
        } else {
            let mut out = format!("鎵惧埌 {} 涓浉鍏虫妧鑳?", results.len());
            for s in &results { out.push_str(&format!("\n- {}: {} ({:.0}%)", s.name, s.description, s.success_rate() * 100.0)); }
            Ok(out)
        }
    }
