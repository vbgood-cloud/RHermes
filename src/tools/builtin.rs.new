// ---------------------------------------------------------------------------
// web_search 鈥?闈炲苟琛屽畨鍏紙缃戠粶璇锋眰锛?// ---------------------------------------------------------------------------

/// 鎼滅储缃戠粶淇℃伅
///
/// 浣跨敤 DuckDuckGo Instant Answer API锛屾棤闇€ API Key銆?/// 杩斿洖鎼滅储缁撴灉鎽樿鍜岀浉鍏抽摼鎺ャ€?pub struct WebSearch;

#[async_trait]
impl Tool for WebSearch {
    fn name(&self) -> &'static str {
        "web_search"
    }
    fn description(&self) -> &'static str {
        "鎼滅储缃戠粶鑾峰彇鏈€鏂颁俊鎭?
    }
    fn parallel_safe(&self) -> bool {
        false
    }
    fn parameters(&self) -> Vec<ParamDef> {
        vec![
            ParamDef::required("query", ParamType::String, "鎼滅储鍏抽敭璇?),
        ]
    }
    async fn execute(&self, args: Value) -> Result<String, ToolError> {
        let query = get_string_arg(&args, "query")?;
        let url = format!(
            "https://api.duckduckgo.com/?q={}&format=json&no_html=1&skip_disambig=1",
            urlencoding(&query)
        );

        let resp = reqwest::get(&url)
            .await
            .map_err(|e| ToolError::ExecutionFailed(format!("鎼滅储璇锋眰澶辫触: {e}")))?;

        let body: serde_json::Value = resp
            .json()
            .await
            .map_err(|e| ToolError::ExecutionFailed(format!("瑙ｆ瀽鎼滅储缁撴灉澶辫触: {e}")))?;

        let mut results = Vec::new();

        // 鎽樿
        if let Some(abstract_text) = body["AbstractText"].as_str() {
            if !abstract_text.is_empty() {
                results.push(format!("馃摑 鎽樿: {abstract_text}"));
                if let Some(src) = body["AbstractSource"].as_str() {
                    results.push(format!("   鏉ユ簮: {src}"));
                }
                if let Some(url) = body["AbstractURL"].as_str() {
                    results.push(format!("   閾炬帴: {url}"));
                }
                results.push(String::new());
            }
        }

        // 绛旀
        if let Some(answer) = body["Answer"].as_str() {
            if !answer.is_empty() {
                results.push(format!("馃挕 绛旀: {answer}"));
                if let Some(url) = body["AnswerURL"].as_str() {
                    if !url.is_empty() {
                        results.push(format!("   閾炬帴: {url}"));
                    }
                }
                results.push(String::new());
            }
        }

        // 鐩稿叧缁撴灉
        if let Some(topics) = body["RelatedTopics"].as_array() {
            for topic in topics.iter().take(8) {
                if let Some(text) = topic["Text"].as_str() {
                    if let Some(url) = topic["FirstURL"].as_str() {
                        results.push(format!("馃敆 {text}"));
                        results.push(format!("   {url}"));
                    } else {
                        results.push(format!("馃敆 {text}"));
                    }
                }
                // 澶勭悊宓屽鐨?Topics
                if let Some(sub_topics) = topic["Topics"].as_array() {
                    for sub in sub_topics.iter().take(3) {
                        if let Some(text) = sub["Text"].as_str() {
                            if let Some(url) = sub["FirstURL"].as_str() {
                                results.push(format!("  鈥?{text}"));
                                results.push(format!("    {url}"));
                            }
                        }
                    }
                }
            }
        }

        if results.is_empty() {
            Ok(format!("鏈壘鍒颁笌銆寋query}銆嶇浉鍏崇殑鎼滅储缁撴灉"))
        } else {
            Ok(format!("鎼滅储缁撴灉銆寋query}銆?\n{}", results.join("\n")))
        }
    }
#OFFICE_MARKER

/// URL 缂栫爜锛堢畝鍗曠増鏈紝浠呯紪鐮佷腑鏂囧拰鐗规畩瀛楃锛?fn urlencoding(input: &str) -> String {
    let mut result = String::with_capacity(input.len());
    for byte in input.bytes() {
        match byte {
            b'A'..=b'Z' | b'a'..=b'z' | b'0'..=b'9' | b'-' | b'_' | b'.' | b'~' => {
                result.push(byte as char);
            }
            b' ' => result.push_str("%20"),
            _ => {
                result.push_str(&format!("%{:02X}", byte));
            }
        }
    }
    result
#OFFICE_MARKER

// ---------------------------------------------------------------------------
// web_fetch 鈥?闈炲苟琛屽畨鍏紙缃戠粶璇锋眰锛?// ---------------------------------------------------------------------------

/// 鑾峰彇缃戦〉鍐呭
///
/// 涓嬭浇鎸囧畾 URL 鐨勫唴瀹瑰苟鎻愬彇鍙鏂囨湰銆?pub struct WebFetch;

#[async_trait]
impl Tool for WebFetch {
    fn name(&self) -> &'static str {
        "web_fetch"
    }
    fn description(&self) -> &'static str {
        "鑾峰彇缃戦〉鍐呭骞舵彁鍙栧彲璇绘枃鏈?
    }
    fn parallel_safe(&self) -> bool {
        false
    }
    fn parameters(&self) -> Vec<ParamDef> {
        vec![
            ParamDef::required("url", ParamType::String, "瑕佽幏鍙栫殑缃戦〉 URL"),
            ParamDef::optional("max_chars", ParamType::Integer, "鏈€澶у瓧绗︽暟锛堥粯璁?5000锛?),
        ]
    }
    async fn execute(&self, args: Value) -> Result<String, ToolError> {
        let url = get_string_arg(&args, "url")?;
        let max_chars = args
            .get("max_chars")
            .and_then(|v| v.as_u64())
            .unwrap_or(5000) as usize;

        let resp = reqwest::get(&url)
            .await
            .map_err(|e| ToolError::ExecutionFailed(format!("璇锋眰澶辫触: {e}")))?;

        let status = resp.status();
        let content_type = resp
            .headers()
            .get("content-type")
            .and_then(|v| v.to_str().ok())
            .unwrap_or("")
            .to_string();

        let body = resp
            .text()
            .await
            .map_err(|e| ToolError::ExecutionFailed(format!("璇诲彇鍝嶅簲澶辫触: {e}")))?;

        // 鎻愬彇鍙鏂囨湰锛堢畝鍗?HTML 鏍囩鍓ョ锛?        let text = if content_type.contains("text/html") {
            strip_html_tags(&body)
        } else {
            body.clone()
        };

        // 鎴柇
        let text: String = text.chars().take(max_chars).collect();
        let total_len = body.len();
        let text_len = text.len();

        let extra = if text_len < total_len {
            format!("\n...(鏄剧ず {} 瀛楃锛屽叡 {} 瀛楃)", text_len, total_len)
        } else {
            String::new()
        };
        Ok(format!(
            "[{}] HTTP {status} 路 {content_type}\n{}{}",
            url, text, extra,
        ))
    }
#OFFICE_MARKER

/// 绠€鍗曠殑 HTML 鏍囩鍓ョ
fn strip_html_tags(html: &str) -> String {
    let mut result = String::with_capacity(html.len());
    let mut in_tag = false;
    let mut in_script = false;
    let mut in_style = false;

    let lower = html.to_lowercase();
    let bytes = html.as_bytes();
    let lower_bytes = lower.as_bytes();

    let mut i = 0;
    while i < bytes.len() {
        if !in_tag && bytes[i] == b'<' {
            // 妫€娴?<script 鍜?<style
            let rest_lower = &lower[i..];
            in_script = rest_lower.starts_with("<script");
            in_style = rest_lower.starts_with("<style");
            in_tag = true;
            i += 1;
            continue;
        }
        if in_tag && bytes[i] == b'>' {
            // 妫€娴?</script> 鍜?</style>
            if (in_script && lower_bytes[i.saturating_sub(8)..=i].windows(9).any(|w| w == b"</script>"))
                || (in_style && lower_bytes[i.saturating_sub(6)..=i].windows(7).any(|w| w == b"</style>"))
            {
                in_script = false;
                in_style = false;
            }
            in_tag = false;
            i += 1;
            if !in_script && !in_style {
                result.push(' ');
            }
            continue;
        }
        if in_tag || in_script || in_style {
            i += 1;
            continue;
        }
        // 鍚堝苟澶氫釜绌虹櫧
        if bytes[i] == b' ' || bytes[i] == b'\t' || bytes[i] == b'\n' || bytes[i] == b'\r' {
            if !result.ends_with(' ') {
                result.push(' ');
            }
        } else {
            result.push(bytes[i] as char);
        }
        i += 1;
    }

    result.trim().to_string()
#OFFICE_MARKER

