/// 鎵ц宸插畨瑁呯殑鎶€鑳?pub struct RunSkill;

#[async_trait]
impl Tool for RunSkill {
    fn name(&self) -> &'static str {
        "run_skill"
    }
    fn description(&self) -> &'static str {
        "鎵ц涓€涓凡瀹夎鐨勬妧鑳藉苟杩斿洖缁撴灉"
    }
    fn parallel_safe(&self) -> bool {
        false
    }
    fn parameters(&self) -> Vec<ParamDef> {
        vec![
            ParamDef::required("name", ParamType::String, "鎶€鑳藉悕绉?),
            ParamDef::required("arguments", ParamType::String, "浼犵粰鎶€鑳界殑浠诲姟鎻忚堪"),
        ]
    }
    async fn execute(&self, args: Value) -> Result<String, ToolError> {
        let name = get_string_arg(&args, "name")?;
        let arguments = get_string_arg(&args, "arguments")?;

        let engine_arc = GLOBAL_SKILL_ENGINE.get().ok_or_else(|| {
            ToolError::ExecutionFailed("鎶€鑳藉紩鎿庢湭鍒濆鍖?.into())
        })?;

        // 鏌ユ壘鎶€鑳斤紙閿佷綔鐢ㄥ煙锛屽湪 await 鍓嶉噴鏀撅級
        let skill = {
            let engine = engine_arc.lock().map_err(|e| {
                ToolError::ExecutionFailed(format!("鎶€鑳藉紩鎿庨攣瀹氬け璐? {e}"))
            })?;
            engine.get(&name).cloned().ok_or_else(|| {
                ToolError::ExecutionFailed(format!("鎶€鑳姐€寋name}銆嶄笉瀛樺湪"))
            })?
        };

        let result = skill.run(&arguments).await;

        // 璁板綍浣跨敤鎯呭喌
        if let Ok(mut engine) = engine_arc.lock() {
            let _ = engine.record_usage(&name, result.success, result.duration_ms as u64);
        }

        if result.success {
            Ok(format!("銆愭妧鑳姐€寋name}銆嶇粨鏋溿€慭n{}\n銆愯€楁椂: {}ms銆?, result.output, result.duration_ms))
        } else {
            Ok(format!("銆愭妧鑳姐€寋name}銆嶆墽琛屽け璐ャ€慭n{}", result.output))
        }
    }
#OFFICE_MARKER

