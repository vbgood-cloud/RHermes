// skill_create 鈥?闈炲苟琛屽畨鍏紙鍐欑鐩橈級
// ---------------------------------------------------------------------------
pub struct SkillCreate;

#[async_trait]
impl Tool for SkillCreate {
    fn name(&self) -> &'static str { "skill_create" }
    fn description(&self) -> &'static str { "鍒涘缓鏂扮殑鍙鐢ㄦ妧鑳斤紝璁?AI 涓嶆柇绉疮鏈€浣冲疄璺? }
    fn parallel_safe(&self) -> bool { false }
    fn parameters(&self) -> Vec<ParamDef> {
        vec![
            ParamDef::required("name", ParamType::String, "鎶€鑳藉悕绉帮紙灏忓啓鑻辨枃+鐭í绾匡級"),
            ParamDef::required("description", ParamType::String, "涓€鍙ヨ瘽鎻忚堪璇ユ妧鑳界殑鐢ㄩ€?),
            ParamDef::required("body", ParamType::String, "鎶€鑳芥鏂?Markdown锛屾弿杩版墽琛屾楠ゅ拰娉ㄦ剰浜嬮」"),
            ParamDef::optional("category", ParamType::String, "鎶€鑳藉垎绫荤洰褰曪紙濡?analysis/utils/debug锛夛紝涓嶅～鍒欐斁鏍圭洰褰?),
            ParamDef::optional("allowed_tools", ParamType::String, "鍏佽鐨勫伐鍏峰垪琛紝閫楀彿鍒嗛殧"),
        ]
    }
    async fn execute(&self, args: Value) -> Result<String, ToolError> {
        let name = get_string_arg(&args, "name")?;
        let description = get_string_arg(&args, "description")?;
        let body = get_string_arg(&args, "body")?;
        let category = get_optional_string(&args, "category");
        let category_str = category.as_deref();
        let allowed_tools = get_optional_string(&args, "allowed_tools").unwrap_or_default();
        let engine_arc = GLOBAL_SKILL_ENGINE.get().ok_or_else(|| ToolError::ExecutionFailed("鎶€鑳藉紩鎿庢湭鍒濆鍖?.into()))?;
        let tools_str = if allowed_tools.is_empty() { String::new() } else {
            format!("\nallowed_tools:\n  - {}", allowed_tools.split(',').map(|s| s.trim().to_string()).collect::<Vec<_>>().join("\n  - "))
        };
        let skill_body = format!("---\nname: {name}\ndescription: {description}\nrun_as: subagent{tools_str}\n---\n\n# {name}\n\n{body}");
        { let mut engine = engine_arc.lock().map_err(|e| ToolError::ExecutionFailed(format!("閿佸畾澶辫触: {e}")))?;
          engine.create_with_category(&name, category_str, &description, &skill_body, crate::agent::RunAs::Subagent).map_err(|e| ToolError::ExecutionFailed(format!("鍒涘缓澶辫触: {e}")))?; }
        Ok(format!("鉁?鎶€鑳姐€寋name}銆嶅凡鍒涘缓锛乗n鎻忚堪: {description}\n\n鐜板湪鍙互浣跨敤 run_skill(name=\"{name}\") 鏉ヨ皟鐢ㄦ鎶€鑳姐€?))
    }
#OFFICE_MARKER

