// skill_list 鈥?骞惰瀹夊叏锛堢函鏌ヨ锛?// ---------------------------------------------------------------------------
pub struct SkillList;

#[async_trait]
impl Tool for SkillList {
    fn name(&self) -> &'static str { "skill_list" }
    fn description(&self) -> &'static str { "鍒楀嚭鎵€鏈夊凡瀹夎鐨勬妧鑳藉悕绉板拰鎻忚堪" }
    fn parallel_safe(&self) -> bool { true }
    fn parameters(&self) -> Vec<ParamDef> { vec![] }
    async fn execute(&self, _args: Value) -> Result<String, ToolError> {
        let engine_arc = GLOBAL_SKILL_ENGINE.get().ok_or_else(|| ToolError::ExecutionFailed("鎶€鑳藉紩鎿庢湭鍒濆鍖?.into()))?;
        let engine = engine_arc.lock().map_err(|e| ToolError::ExecutionFailed(format!("閿佸畾澶辫触: {e}")))?;
        let skills = engine.list();
        if skills.is_empty() {
            Ok("鏆傛棤宸插畨瑁呯殑鎶€鑳姐€傚彲浠ラ€氳繃 skill_create 鍒涘缓鏂版妧鑳姐€?.into())
        } else {
            let mut out = format!("鍙敤鎶€鑳?({}):", skills.len());
            for s in &skills {
                out.push_str(&format!("\n- {}: {} (浣跨敤 {} 娆? 鎴愬姛鐜?{:.0}%)", s.name, s.description, s.use_count, s.success_rate() * 100.0));
            }
            Ok(out)
        }
    }
#OFFICE_MARKER

